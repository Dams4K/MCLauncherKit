[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.7
reloadable = true

[libraries]
linux.debug.x86_64 =     "./bin/release/libjava_runner.so"
linux.release.x86_64 =   "./bin/release/libjava_runner.so"
windows.debug.x86_64 =   "./bin/release/java_runner.dll"
windows.release.x86_64 = "./bin/release/java_runner.dll"
